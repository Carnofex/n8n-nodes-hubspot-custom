{
  "name": "n8n-nodes-hubspot-custom",
  "version": "0.1.0",
  "description": "n8n node for HubSpot with configurable OAuth2 scopes - supports custom objects",
  "keywords": [
    "n8n-community-node-package",
    "hubspot",
    "custom-objects",
    "oauth2"
  ],
  "license": "MIT",
  "author": {
    "name": "Timothy",
    "email": "timothy.dalton@gilamon.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Carnofex/n8n-nodes-hubspot-custom.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/HubspotCustomOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/HubspotCustom/HubspotCustom.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "~7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.2.0",
    "typescript": "~5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
